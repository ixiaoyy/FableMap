{
  "version": "0.1-draft",
  "status": "draft",
  "name": "causal_ripple_rules",
  "source_design_doc": "docs/CAUSAL_RIPPLE_ALGORITHM.md",
  "supported_source_kinds": [
    "poi",
    "road",
    "region",
    "landmark",
    "faction_action"
  ],
  "formula": {
    "base_expression": "source_intensity * carrier_weight * distance_decay * context_modifier",
    "score_range": [
      0.0,
      1.0
    ],
    "default_decay": {
      "kind": "linear_radius_decay",
      "min_effect": 0.15,
      "max_hops": 3
    },
    "notes": [
      "This file is a machine-readable draft, not a frozen runtime API.",
      "Writeback targets must prefer fields already defined in docs/WORLD_SCHEMA.md."
    ]
  },
  "carrier_types": [
    {
      "id": "spatial_proximity",
      "label": "空间邻近",
      "default_weight": 0.9,
      "distance_model": "linear_radius_decay",
      "preferred_targets": [
        "nearby_pois",
        "adjacent_landmarks",
        "same_block"
      ]
    },
    {
      "id": "road_network",
      "label": "路网传播",
      "default_weight": 0.85,
      "distance_model": "reachable_path_decay",
      "preferred_targets": [
        "connected_roads",
        "commuter_links",
        "market_streets"
      ]
    },
    {
      "id": "street_sentence",
      "label": "街句语法传播",
      "default_weight": 0.75,
      "distance_model": "syntax_hop_decay",
      "preferred_targets": [
        "repeat_nodes",
        "contrast_nodes",
        "closure_nodes"
      ]
    },
    {
      "id": "faction_network",
      "label": "阵营传播",
      "default_weight": 0.8,
      "distance_model": "control_link_decay",
      "preferred_targets": [
        "same_faction_nodes",
        "rival_faction_nodes",
        "checkpoint_clusters"
      ]
    },
    {
      "id": "resource_flow",
      "label": "资源流传播",
      "default_weight": 0.7,
      "distance_model": "upstream_downstream_decay",
      "preferred_targets": [
        "supply_inputs",
        "consumer_nodes",
        "replacement_nodes"
      ]
    },
    {
      "id": "memory_anomaly",
      "label": "记忆/异常传播",
      "default_weight": 0.55,
      "distance_model": "echo_decay",
      "preferred_targets": [
        "historical_echoes",
        "memory_anchors",
        "ritual_paths"
      ]
    }
  ],
  "impact_layers": [
    {
      "id": "control",
      "label": "秩序/控制层",
      "region_fields": [
        "social_tension",
        "atmosphere",
        "satire_profile"
      ],
      "state_fields": [
        "faction_states",
        "route_impact",
        "story_events"
      ],
      "poi_effect_keys": [
        "alert",
        "checkpoint_expansion",
        "suspicion"
      ]
    },
    {
      "id": "supply",
      "label": "补给/经济层",
      "region_fields": [
        "commerce_flux",
        "satire_profile"
      ],
      "state_fields": [
        "economy_state",
        "resource_transfers",
        "route_impact"
      ],
      "poi_effect_keys": [
        "price_shift",
        "shortage",
        "panic_buying"
      ]
    },
    {
      "id": "care",
      "label": "关怀/修复层",
      "region_fields": [
        "comfort_level",
        "atmosphere"
      ],
      "state_fields": [
        "poi_states",
        "story_events"
      ],
      "poi_effect_keys": [
        "overload",
        "exhaustion",
        "spillover_queue"
      ]
    },
    {
      "id": "emotion",
      "label": "情绪层",
      "region_fields": [
        "atmosphere",
        "vibe_profile",
        "comfort_level"
      ],
      "state_fields": [
        "story_events",
        "active_lens"
      ],
      "poi_effect_keys": [
        "fear",
        "fatigue",
        "relief_loss"
      ]
    },
    {
      "id": "anomaly",
      "label": "异常/历史层",
      "region_fields": [
        "anomaly_pressure",
        "vibe_profile"
      ],
      "state_fields": [
        "story_events",
        "signal_snapshot",
        "active_lens"
      ],
      "poi_effect_keys": [
        "echo_activation",
        "memory_leak",
        "mystery_opening"
      ]
    },
    {
      "id": "aesthetic",
      "label": "审美/镜头层",
      "region_fields": [
        "vibe_profile",
        "palette_hint",
        "atmosphere"
      ],
      "state_fields": [
        "active_lens",
        "story_events"
      ],
      "poi_effect_keys": [
        "lens_pull",
        "tone_shift",
        "audio_bias"
      ]
    }
  ],
  "context_modifiers": [
    {
      "id": "high_disturbance",
      "source_field": "state.disturbance_level",
      "effect": "amplify_all_layers",
      "multiplier": 1.2
    },
    {
      "id": "night_time",
      "source_field": "state.signal_snapshot",
      "effect": "boost_emotion_and_anomaly",
      "multiplier": 1.15
    },
    {
      "id": "rain_or_low_visibility",
      "source_field": "state.signal_snapshot",
      "effect": "boost_aesthetic_and_route_risk",
      "multiplier": 1.1
    },
    {
      "id": "commuter_peak",
      "source_field": "state.signal_snapshot",
      "effect": "boost_supply_and_control",
      "multiplier": 1.1
    },
    {
      "id": "high_baseline_comfort",
      "source_field": "region.comfort_level",
      "effect": "dampen_emotion_shock",
      "multiplier": 0.9
    }
  ],
  "event_templates": [
    {
      "id": "control_breach",
      "label": "控制破裂事件",
      "example_sources": [
        "judgement_tower",
        "order_bureau"
      ],
      "default_source_intensity": 0.8,
      "default_radius_meters": 1000,
      "time_window_minutes": 180,
      "carrier_weights": {
        "spatial_proximity": 0.8,
        "road_network": 0.7,
        "street_sentence": 0.6,
        "faction_network": 1.0,
        "resource_flow": 0.5,
        "memory_anomaly": 0.3
      },
      "impact_layers": [
        "control",
        "emotion",
        "supply",
        "aesthetic"
      ],
      "writeback": {
        "region": [
          "social_tension",
          "atmosphere",
          "satire_profile"
        ],
        "state": [
          "faction_states",
          "route_impact",
          "story_events"
        ]
      },
      "poi_state_effects": [
        "alert",
        "panic_buying",
        "checkpoint_expansion"
      ],
      "example_chain": "judgement_tower sabotage -> trade street -> supply_outpost cluster"
    },
    {
      "id": "supply_shock",
      "label": "补给冲击事件",
      "example_sources": [
        "supply_outpost",
        "trade_guild"
      ],
      "default_source_intensity": 0.75,
      "default_radius_meters": 1200,
      "time_window_minutes": 240,
      "carrier_weights": {
        "spatial_proximity": 0.6,
        "road_network": 0.95,
        "street_sentence": 0.5,
        "faction_network": 0.65,
        "resource_flow": 1.0,
        "memory_anomaly": 0.2
      },
      "impact_layers": [
        "supply",
        "emotion",
        "control"
      ],
      "writeback": {
        "region": [
          "commerce_flux",
          "atmosphere",
          "satire_profile"
        ],
        "state": [
          "economy_state",
          "resource_transfers",
          "route_impact"
        ]
      },
      "poi_state_effects": [
        "shortage",
        "price_shift",
        "queue_extension"
      ],
      "example_chain": "supply_outpost shortage -> market street -> replacement nodes"
    },
    {
      "id": "care_overload",
      "label": "治愈过载事件",
      "example_sources": [
        "healing_sanctum",
        "whispering_grove"
      ],
      "default_source_intensity": 0.7,
      "default_radius_meters": 900,
      "time_window_minutes": 300,
      "carrier_weights": {
        "spatial_proximity": 0.85,
        "road_network": 0.55,
        "street_sentence": 0.7,
        "faction_network": 0.45,
        "resource_flow": 0.6,
        "memory_anomaly": 0.35
      },
      "impact_layers": [
        "care",
        "emotion",
        "aesthetic"
      ],
      "writeback": {
        "region": [
          "comfort_level",
          "atmosphere",
          "vibe_profile"
        ],
        "state": [
          "poi_states",
          "story_events",
          "active_lens"
        ]
      },
      "poi_state_effects": [
        "overload",
        "exhaustion",
        "relief_loss"
      ],
      "example_chain": "healing_sanctum overload -> ember_parlor -> whispering_grove"
    },
    {
      "id": "anomaly_ignition",
      "label": "异常点火事件",
      "example_sources": [
        "historical_echo",
        "memory_anchor",
        "landmark"
      ],
      "default_source_intensity": 0.72,
      "default_radius_meters": 800,
      "time_window_minutes": 150,
      "carrier_weights": {
        "spatial_proximity": 0.5,
        "road_network": 0.4,
        "street_sentence": 0.7,
        "faction_network": 0.35,
        "resource_flow": 0.25,
        "memory_anomaly": 1.0
      },
      "impact_layers": [
        "anomaly",
        "emotion",
        "aesthetic"
      ],
      "writeback": {
        "region": [
          "anomaly_pressure",
          "vibe_profile",
          "atmosphere"
        ],
        "state": [
          "signal_snapshot",
          "story_events",
          "active_lens"
        ]
      },
      "poi_state_effects": [
        "echo_activation",
        "memory_leak",
        "mystery_opening"
      ],
      "example_chain": "night rain -> landmark echo -> ritual path -> memory_anchor"
    },
    {
      "id": "aesthetic_surge",
      "label": "审美放大事件",
      "example_sources": [
        "ember_parlor",
        "station",
        "whispering_grove"
      ],
      "default_source_intensity": 0.65,
      "default_radius_meters": 700,
      "time_window_minutes": 120,
      "carrier_weights": {
        "spatial_proximity": 0.55,
        "road_network": 0.6,
        "street_sentence": 0.9,
        "faction_network": 0.25,
        "resource_flow": 0.3,
        "memory_anomaly": 0.5
      },
      "impact_layers": [
        "aesthetic",
        "emotion",
        "anomaly"
      ],
      "writeback": {
        "region": [
          "vibe_profile",
          "palette_hint",
          "atmosphere"
        ],
        "state": [
          "active_lens",
          "story_events"
        ]
      },
      "poi_state_effects": [
        "lens_pull",
        "tone_shift",
        "audio_bias"
      ],
      "example_chain": "rainy station corridor -> convenience strip -> neon_nostalgia lens"
    }
  ],
  "writeback_targets": {
    "region_fields": [
      "social_tension",
      "commerce_flux",
      "anomaly_pressure",
      "comfort_level",
      "atmosphere",
      "satire_profile",
      "vibe_profile",
      "palette_hint"
    ],
    "state_fields": [
      "disturbance_level",
      "signal_snapshot",
      "story_events",
      "poi_states",
      "faction_states",
      "economy_state",
      "route_impact",
      "resource_transfers",
      "active_lens"
    ],
    "poi_fields": [
      "satire_hook",
      "emotion_hook"
    ],
    "memory_fields": [
      "historical_echoes.trigger_hint",
      "memory_anchors.unlock_conditions"
    ]
  },
  "notes": [
    "Event templates are defaults and are expected to be specialized by future runtime rules.",
    "Example sources intentionally reuse fantasy types and factions that already appear in the current codebase or design docs.",
    "A future inspect command can explain which carrier, layer and writeback path produced a given ripple outcome."
  ]
}