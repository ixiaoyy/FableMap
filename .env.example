# FableMap Docker / local deployment environment
# Copy to `.env` before running docker compose if you need to override defaults.

# Published host ports
FABLEMAP_FRONTEND_PORT=3000
FABLEMAP_API_PORT=8000

# Backend persistence
# Empty value keeps the default JSON-file store in the Docker volume `fablemap_data`.
FABLEMAP_MYSQL_URL=
FABLEMAP_SEED_DEFAULT_TAVERNS=1

# Browser/API origins used by local deployments.
FABLEMAP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend build-time API base.
# Leave empty to use same-origin `/api` paths through nginx.
VITE_API_BASE=

# Owner LLM API keys are configured per owner/tavern inside FableMap.
# Do not put private owner API keys in this shared compose env file.
